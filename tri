show databases;
create database arohan;
use arohan;
create table eventfee(event_id int,fee int);
CREATE TRIGGER ins_sum1 
BEFORE INSERT ON eventfee 
FOR EACH ROW 
SET @fee = @fee + NEW.fee;

set @fee = 0;
insert into eventfee values(1,5),(2,10),(3,15),(4,20);
select @fee as 'total fee inserted';
select * from eventfee;

CREATE VIEW event_view AS 
SELECT event_id, fee FROM eventfee;

select * from event_view;
